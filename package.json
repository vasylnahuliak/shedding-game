{
  "name": "shedding-game",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "22.22.2"
  },
  "overrides": {
    "react": "19.2.0"
  },
  "scripts": {
    "frontend": "npm run -w shedding-game-frontend",
    "backend": "npm run -w shedding-game-backend",
    "predev": "npm run dev:services",
    "dev": "turbo run dev",
    "supabase:start": "npx supabase@latest start --yes --workdir . -x realtime,imgproxy,storage-api,edge-runtime,logflare,vector,supavisor",
    "supabase:stop": "npx supabase@latest stop --yes --workdir .",
    "supabase:status": "npx supabase@latest status --workdir .",
    "supabase:env": "node scripts/sync-local-supabase-env.mjs",
    "infra:up": "npm run supabase:start && npm run supabase:env && npm run db:ensure -w shedding-game-backend",
    "infra:down": "npm run db:down -w shedding-game-backend && npm run supabase:stop",
    "infra:logs": "npm run db:logs -w shedding-game-backend",
    "dev:services": "npm run infra:up",
    "dev:frontend": "npm run start -w shedding-game-frontend",
    "dev:backend": "npm run dev -w shedding-game-backend",
    "dev:down": "npm run infra:down",
    "dev:logs": "npm run infra:logs",
    "build": "turbo run build",
    "build:shared": "turbo run build --filter=@shedding-game/shared",
    "build:frontend": "turbo run build --filter=shedding-game-frontend",
    "build:backend": "turbo run build --filter=shedding-game-backend",
    "deploy:oracle": "bash deploy/oracle/compose-env.sh",
    "expo:doctor": "npm exec --workspace shedding-game-frontend expo-doctor",
    "expo:install": "npm exec --workspace shedding-game-frontend -- expo install --check && npm install",
    "expo:fix": "npm exec --workspace shedding-game-frontend -- expo install --fix && npm install",
    "i18n:check": "bash scripts/check-i18n.sh",
    "fix": "npm run unused:fix; npm run typecheck; npm run lint:fix; npm run format; npm run cpd",
    "typecheck": "turbo run typecheck",
    "cpd": "jscpd",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier  --write --log-level error .",
    "format:check": "prettier --check .",
    "unused": "knip",
    "unused:fix": "knip --fix --allow-remove-files --format --treat-config-hints-as-errors",
    "clean": "rimraf --glob \"**/node_modules\" \"**/.turbo\" \"**/dist\" \"**/.expo\" \"**/android\" \"**/ios\" \"**/reports\""
  },
  "devDependencies": {
    "@jscpd/html-reporter": "^4.0.4",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "jscpd": "^4.0.8",
    "knip": "^6.0.5",
    "prettier": "^3.4.2",
    "rimraf": "^6.1.3",
    "skills": "^1.4.4",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.32.0"
  }
}
