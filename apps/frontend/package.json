{
  "name": "shedding-game-frontend",
  "main": "index.js",
  "version": "1.0.0",
  "engines": {
    "node": "22.22.2"
  },
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "run:android": "expo run:android",
    "run:ios": "expo run:ios",
    "build:ios": "sh ./scripts/with-secrets.sh eas build --local --platform ios --profile production",
    "build:android": "sh ./scripts/with-secrets.sh eas build --local --platform android --profile production",
    "prebuild:clean": "expo prebuild --clean",
    "build": "node -e \"console.log('Native-only frontend: use build:ios or build:android')\"",
    "sentry:upload:eas-update-sourcemaps": "SENTRY_PROJECT=${SENTRY_PROJECT_MOBILE:-$SENTRY_PROJECT} sentry-expo-upload-sourcemaps dist",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
