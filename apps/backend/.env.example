# Copy this file to one of:
# - .env.local for local development
# - .env.staging for staging
# - .env.production for production
APP_ENV="local"

# Postgres connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Supabase JWT verification (required for all auth flows)
# Local development defaults:
# SUPABASE_URL="http://127.0.0.1:54321"
# SUPABASE_JWT_ISSUER="http://127.0.0.1:54321/auth/v1"
# SUPABASE_JWT_AUDIENCE="authenticated"
# Required for account deletion (server-side Supabase admin API)
# For local development, run `npm run supabase:env` to write the current service role key into `.env.local`.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SECRET_KEY="YOUR_SUPABASE_SECRET_KEY"
# Optional override (defaults to "<SUPABASE_URL>/auth/v1")
# SUPABASE_JWT_ISSUER="https://YOUR_PROJECT_REF.supabase.co/auth/v1"
# Optional override (defaults to "authenticated")
# SUPABASE_JWT_AUDIENCE="authenticated"

# Production reverse proxy / CORS
# CORS_ALLOWED_ORIGINS="https://example.com"
# TRUST_PROXY_HOPS=1
# PUBLIC_APP_URL="https://example.com"
# SMLER_API_KEY="YOUR_SMLER_API_KEY"

# Sentry is disabled when APP_ENV=local.
# Required when APP_ENV is staging or production.
# SENTRY_DSN="https://PUBLIC_KEY@o0.ingest.sentry.io/0"
# SENTRY_ENVIRONMENT="production"
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional Redis (recommended locally too, so queue/lock/cache issues show up before deploy)
# REDIS_URL="redis://localhost:6379"
# REDIS_KEY_PREFIX="sg"
# REDIS_LOCK_TTL_MS=15000
# REDIS_LOCK_EXTEND_INTERVAL_MS=5000
# REDIS_ROOMS_CACHE_TTL_MS=5000
# REDIS_ALL_GAMES_CACHE_TTL_MS=5000
# REDIS_ACTIVE_GAME_CACHE_TTL_MS=3000
# REDIS_STATS_CACHE_TTL_MS=30000
# REDIS_JOB_POLL_INTERVAL_MS=200
# REDIS_JOB_BATCH_SIZE=20
# REDIS_JOB_MAX_ATTEMPTS=3
# REDIS_JOB_RETRY_INITIAL_BACKOFF_MS=1000
# REDIS_JOB_RETRY_MAX_BACKOFF_MS=30000
# REDIS_JOB_DEAD_LETTER_MAX_SIZE=1000

# Optional
PORT=3000

# Local examples:
# DATABASE_URL="postgresql://shedding:shedding@localhost:5432/shedding_game?sslmode=disable"
# REDIS_URL="redis://localhost:6379"
# SUPABASE_URL="http://127.0.0.1:54321"
# SUPABASE_JWT_ISSUER="http://127.0.0.1:54321/auth/v1"
# SUPABASE_JWT_AUDIENCE="authenticated"
# PUBLIC_APP_URL="http://localhost:8081"
# SMLER_API_KEY="YOUR_SMLER_API_KEY"
