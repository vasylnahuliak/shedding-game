APP_ENV="local"

# Local Postgres
DATABASE_URL="postgresql://shedding:shedding@localhost:5432/shedding_game?sslmode=disable"

# Local Redis (recommended so queue/lock/cache behaviour matches deployed environments)
REDIS_URL="redis://localhost:6379"
REDIS_KEY_PREFIX="sg-local"

# Local Supabase Auth (run `npm run supabase:env` to refresh keys from the local stack)
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_JWT_ISSUER="http://127.0.0.1:54321/auth/v1"
SUPABASE_JWT_AUDIENCE="authenticated"
SUPABASE_SECRET_KEY="YOUR_LOCAL_SUPABASE_SERVICE_ROLE_KEY"
PUBLIC_APP_URL="http://localhost:8081"
SMLER_API_KEY="YOUR_SMLER_API_KEY"

# Sentry is intentionally disabled for APP_ENV=local.

# Optional
PORT=3000
