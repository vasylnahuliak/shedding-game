# 1) Обовʼязково:
# - tenancy_ocid: root tenancy OCID (Identity -> Tenancy details)
# - compartment_ocid: compartment OCID, де створюємо ресурси
# - ssh_public_key_path: шлях до ключа *.pub, який буде додано в authorized_keys

region            = "eu-frankfurt-1"
tenancy_ocid      = "ocid1.tenancy.oc1..REPLACE_ME"
compartment_ocid  = "ocid1.compartment.oc1..REPLACE_ME"
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# 2) Опційно:
