{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "shedding-game-frontend#build": {
      "cache": false
    },
    "shedding-game-backend#build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "outputs": []
    },
    "shedding-game-backend#typecheck": {
      "dependsOn": ["^build", "prisma:generate"]
    },
    "shedding-game-backend#lint": {
      "dependsOn": ["^build", "prisma:generate"]
    },
    "prisma:generate": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "shedding-game-backend#dev": {
      "dependsOn": ["^build", "prisma:generate"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "outputs": []
    }
  }
}
